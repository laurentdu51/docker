services:
  xubuntu:
    image: 'docker.io/hectorm/xubuntu:latest'
    shm_size: '2gb'

    devices:
      - '/dev/dri:/dev/dri'
    environment:
      - UNPRIVILEGED_USER_PASSWORD=mdpmdp
      - UNPRIVILEGED_USER_GROUPS=sudo
    ports:
      - '3728:3728/tcp'
    volumes:
      - /share/Container/Xrdp:/home
      - /share/Music:/home/user/Music
      - /share/Vidéo:/home/user/Video
      - /share/Documents/Images:/home/user/Pictures
      - /share/Documents/Téléchargements:/home/user/Downloads
      - /share/Documents/Documents administratifs:/home/user/Documents/Documents administratifs
      - /var/run/docker.sock:/var/run/docker.sock
    networks:
      - duhaz_network

networks:
  duhaz_network:
    external: true