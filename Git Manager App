# Git Manager App > git_manager:latest
# Pour /mnt/nas/test/git_manager_app

FROM python:3.13-alpine3.21

# Installation des dépendances système
RUN apk add --no-cache tzdata git openssh-server bash py3-pip mariadb-connector-c-dev build-base freetype-dev jpeg-dev gettext zlib-dev libxslt-dev libffi-dev

# Fuseaux horaires
RUN cp /usr/share/zoneinfo/Europe/Paris /etc/localtime && \
    echo Europe/Paris > /etc/timezone && \
    echo Europe/Paris > /etc/TZ && \
    unset TZ && \
    apk del tzdata

# Workdir
WORKDIR /app

# Installation des dépendances Python
RUN pip install --upgrade pip && \
    pip install Django>=4.2 gunicorn python-decouple whitenoise mysqlclient

# Création des dossiers
RUN mkdir -p /app/data /root/.ssh && chmod 700 /root/.ssh

# Copier le code
COPY . .

# Exposition des ports (interne:externe)
# 8000 = HTTP, 22 = SSH (mapping 2222:22 dans compose)
EXPOSE 8000 22

# Entrypoint
CMD ["/app/docker/entrypoint.sh"]